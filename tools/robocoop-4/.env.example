# robocoop-4 eval credentials. Copy to `.env` (gitignored) and fill in.
#   cp tools/robocoop-4/.env.example tools/robocoop-4/.env
# Then: node tools/robocoop-4/eval/run-eval.mjs --real

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Default model for --real runs (overridable with --model). Examples:
#   anthropic/claude-sonnet-4
#   anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=anthropic/claude-sonnet-4
