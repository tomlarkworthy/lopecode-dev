# Minimal Linux config for lopecode RISC-V SBC (rv32imafdc)
# Target: Linux 6.1 LTS

# Architecture
CONFIG_RISCV=y
CONFIG_ARCH_RV32I=y
CONFIG_32BIT=y
CONFIG_RISCV_ISA_A=y
CONFIG_RISCV_ISA_M=y
CONFIG_RISCV_ISA_C=y
CONFIG_FPU=y
CONFIG_CMODEL_MEDLOW=y
CONFIG_MMU=y

# SBI
CONFIG_RISCV_SBI=y
CONFIG_RISCV_SBI_V01=y

# No SMP — single hart
# CONFIG_SMP is not set
CONFIG_NR_CPUS=1

# No modules
# CONFIG_MODULES is not set

# Console and printing
CONFIG_PRINTK=y
CONFIG_TTY=y
CONFIG_SERIAL_CORE=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y
CONFIG_HVC_DRIVER=y
CONFIG_HVC_RISCV_SBI=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Minimal FS for initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_INITRAMFS_COMPRESSION_NONE=y

# Proc and sysfs (kernel needs these)
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y

# No networking
# CONFIG_NET is not set

# No block devices
# CONFIG_BLOCK is not set

# No GPU/DRM
# CONFIG_DRM is not set

# No sound
# CONFIG_SOUND is not set

# No USB
# CONFIG_USB_SUPPORT is not set

# No input devices beyond basic
# CONFIG_INPUT_MOUSEDEV is not set
# CONFIG_INPUT_EVDEV is not set

# Timer
CONFIG_RISCV_TIMER=y
CONFIG_CLINT_TIMER=y

# Embedded/small kernel
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y

# No EFI (MZ header contains compressed instructions)
# CONFIG_EFI is not set
# CONFIG_EFI_STUB is not set

# No debug
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_STACKTRACE is not set

# FDT
CONFIG_OF=y
CONFIG_OF_EARLY_FLATTREE=y

# Misc required
CONFIG_GENERIC_IRQ_CHIP=y
CONFIG_IRQCHIP=y
CONFIG_RISCV_INTC=y
